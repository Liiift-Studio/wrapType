{
	"name": "@liiift-studio/wraptype",
	"version": "1.0.0",
	"description": "Live DOM text wrapping any 3D surface — surface and silhouette modes, orbit camera, built-in shapes plus custom mesh URL",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./r3f": {
			"types": "./dist/r3f.d.ts",
			"import": "./dist/r3f.js",
			"require": "./dist/r3f.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run test && npm run build"
	},
	"peerDependencies": {
		"three": ">=0.160.0",
		"react": ">=17",
		"react-dom": ">=17",
		"@react-three/fiber": ">=8",
		"troika-three-text": ">=0.47"
	},
	"peerDependenciesMeta": {
		"three": {
			"optional": false
		},
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		},
		"@react-three/fiber": {
			"optional": true
		},
		"troika-three-text": {
			"optional": true
		}
	},
	"devDependencies": {
		"@react-three/fiber": "^8.0.0",
		"@types/react": "^19.0.0",
		"@types/three": "^0.170.0",
		"@vitejs/plugin-react": "^4.0.0",
		"happy-dom": "^12.0.0",
		"next": "16.2.2",
		"react": "^19.0.0",
		"three": "^0.170.0",
		"troika-three-text": "^0.47.0",
		"typescript": "^5.0.0",
		"vite": "^6.0.0",
		"vite-plugin-dts": "^4.0.0",
		"vitest": "^3.0.0"
	},
	"keywords": [
		"typography",
		"3d",
		"three.js",
		"mesh",
		"surface",
		"css3d",
		"text-wrap",
		"webgl",
		"interactive",
		"TypeScript",
		"react",
		"npm"
	],
	"author": "Quinn Keaveney <quinn@liiift.studio>",
	"license": "MIT",
	"homepage": "https://wraptype.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/Liiift-Studio/wrapType.git"
	},
	"bugs": {
		"url": "https://github.com/Liiift-Studio/wrapType/issues"
	},
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	}
}
